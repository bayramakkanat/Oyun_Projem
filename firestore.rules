rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı fonksiyonlar ────────────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    // ─── arena_teams ─────────────────────────────────────────────────────────
    match /arena_teams/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn()
                   && docId.matches(request.auth.uid + '_turn.*');
    }

    // ─── arena_leaderboard (kalıcı tek sıralama) ──────────────────────────────
    match /arena_leaderboard/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid)
                   && request.resource.data.bestTurn <= 200
                   && request.resource.data.totalGames <= 10000
                   && request.resource.data.xp <= 100000;
    }

    // ─── arena_leaderboard_{ay} (eski aylık — artık sadece okuma) ──────────
    match /{leaderboardCol}/{uid} {
      allow read: if isLoggedIn()
                  && leaderboardCol.matches('arena_leaderboard_.*');
      allow write: if false;
    }

    // ─── user_profiles ────────────────────────────────────────────────────────
    match /user_profiles/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid);
    }

    // ─── user_tasks ───────────────────────────────────────────────────────────
    match /user_tasks/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ─── usernames ────────────────────────────────────────────────────────────
    // read: tek doküman okuma (getDoc)
    // list: koleksiyon sorgusu (getDocs + where) — arkadaş araması için gerekli
    match /usernames/{username} {
      allow read, list: if true;
      allow create: if isLoggedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isLoggedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ─── animal_stats ─────────────────────────────────────────────────────────
    match /animal_stats/{nick} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn()
                   && request.resource.data.keys().hasOnly(['used', 'wins'])
                   && request.resource.data.used is int
                   && request.resource.data.wins is int
                   && request.resource.data.used >= 0
                   && request.resource.data.wins >= 0
                   && request.resource.data.used <= 1000000
                   && request.resource.data.wins <= 1000000;
    }

    // ─── versus_rooms ─────────────────────────────────────────────────────────
    match /versus_rooms/{code} {
      allow read: if isLoggedIn()
                  && (resource == null
                      || resource.data.status == "waiting"
                      || resource.data.host.uid == request.auth.uid
                      || (resource.data.guest != null
                          && resource.data.guest.uid == request.auth.uid));

      allow create: if isLoggedIn()
                    && request.resource.data.host.uid == request.auth.uid
                    && request.resource.data.status == "waiting"
                    && request.resource.data.keys().hasAll(['host', 'status']);

      allow update: if isLoggedIn()
                    && (resource.data.host.uid == request.auth.uid
                        || (resource.data.guest != null
                            && resource.data.guest.uid == request.auth.uid))
                    && request.resource.data.host.uid == resource.data.host.uid;

      allow delete: if isLoggedIn()
                    && resource.data.host.uid == request.auth.uid;
    }

    // ─── friend_requests ─────────────────────────────────────────────────────
    match /friend_requests/{toUid}/incoming/{fromUid} {
      allow read, delete: if isOwner(toUid);
      allow create: if isLoggedIn()
                    && request.resource.data.uid == request.auth.uid;
    }

    // ─── friends ─────────────────────────────────────────────────────────────
    match /friends/{uid}/list/{friendUid} {
      allow read, write: if isOwner(uid);
    }

    // ─── challenge_invites ────────────────────────────────────────────────────
    match /challenge_invites/{toUid}/invites/{fromUid} {
      allow read: if isOwner(toUid);
      allow create: if isLoggedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(toUid)
                    || isOwner(fromUid);
    }

    // ─── feedback ─────────────────────────────────────────────────────────────
    match /feedback/{docId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if false;
    }

  }
}
