# ─────────────────────────────────────────────────────────────────
# Oyun Projesi — Ortam Değişkenleri
#
# KURULUM:
#   1. Bu dosyayı kopyala:  cp .env.example .env
#   2. .env dosyasındaki değerleri kendi Firebase projenle doldur.
#   3. .env dosyasını asla Git'e commit etme (.gitignore'da olmalı).
#
# Firebase değerlerine nereden ulaşırsın?
#   Firebase Console → Proje Ayarları → Genel → "Uygulamalarınız"
#   bölümündeki SDK kurulum ve yapılandırması kısmından kopyala.
# ─────────────────────────────────────────────────────────────────

REACT_APP_FIREBASE_API_KEY=buraya_api_key_yaz
REACT_APP_FIREBASE_AUTH_DOMAIN=proje-adi.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=proje-adi
REACT_APP_FIREBASE_STORAGE_BUCKET=proje-adi.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=buraya_sender_id_yaz
REACT_APP_FIREBASE_APP_ID=1:sender_id:web:uygulama_id
